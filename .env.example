# Frontend (cliente): mantener en /api para usar proxy local o serverless
VITE_BACKEND_URL=/api

# Backend para proxy local (Vite) y serverless (Vercel):
# Usa SOLO una de las siguientes lineas (comenta/descomenta segun el caso).
# Local con backend local:
# BACKEND_URL=http://localhost:8080
# Local con backend deployado o Vercel:
BACKEND_URL=tu-backend-deployado-o-vercel-url
